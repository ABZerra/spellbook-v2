{
  "name": "spellbook",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "apps/web",
    "apps/extension"
  ],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "npm run dev --prefix apps/web",
    "test": "npm run test:web && npm run test:extension && npm run test:docs",
    "test:web": "npm run test --prefix apps/web",
    "test:extension": "npm run test --prefix apps/extension",
    "test:docs": "node scripts/check-docs.mjs",
    "build": "npm run build:web",
    "build:web": "npm run build --prefix apps/web",
    "build:pages": "node scripts/build-pages.mjs",
    "snapshot:import": "node scripts/import-spells-csv.mjs"
  },
  "engines": {
    "node": ">=20"
  }
}
